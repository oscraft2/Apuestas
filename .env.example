# ── Telegram ──────────────────────────────────────────
# Obtener de @BotFather en Telegram
TELEGRAM_TOKEN=tu_token_aqui

# Chat ID donde enviar los reportes automáticos
# Obtener enviando un mensaje al bot y consultando:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ── The Odds API ──────────────────────────────────────
# https://the-odds-api.com — Plan gratuito: 500 req/mes
ODDS_API_KEY=tu_key_aqui

# ── API-Football ──────────────────────────────────────
# https://api-football.com — Plan gratuito: 100 req/día
FOOTBALL_API_KEY=tu_key_aqui

# ── DeepSeek IA ───────────────────────────────────────
# https://platform.deepseek.com — 5M tokens gratis al registrarse
# Luego ~$0.28/M input tokens
DEEPSEEK_API_KEY=tu_key_aqui
