# ── Telegram ──────────────────────────────────────────
TELEGRAM_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ── The Odds API ──────────────────────────────────────
# https://the-odds-api.com — 500 req/mes gratis
ODDS_API_KEY=tu_key_aqui

# ── API-Football ──────────────────────────────────────
# https://api-football.com — 100 req/día gratis
FOOTBALL_API_KEY=tu_key_aqui

# ── DeepSeek IA ───────────────────────────────────────
# https://platform.deepseek.com — 5M tokens gratis
DEEPSEEK_API_KEY=tu_key_aqui

# ── API REST (opcional) ───────────────────────────────
# Para el dashboard web. Ejecutar con: python main.py both
API_HOST=0.0.0.0
API_PORT=8000

# Panel Admin (pestaña Admin en el dashboard — gestión Premium)
# Genera un string largo aleatorio; el mismo valor se pega en la web.
ADMIN_TOKEN=

# ── Ligas y horarios del análisis central ─────────────
# IDs API-Football, separados por comas. Vacío = Américas (Chile, Brasil, MX, MLS…).
# https://www.api-football.com/documentation-v3#tag/Leagues
TARGET_LEAGUES=265,71,262,253,128,239

# Liga “protagonista”: pequeño boost en el ranking de destacados (default Chile 265).
HERO_LEAGUE_ID=265

# Horas UTC del análisis automático (3 pasadas por defecto).
REPORT_HOURS_UTC=8,15,22

# Regiones de casas para The Odds API (us ayuda a MLS/Liga MX; cuesta más crédito).
ODDS_REGIONS=us,eu,uk

# ── Frontend ──────────────────────────────────────────
# En frontend/.env.local:
# REACT_APP_API_URL=http://localhost:8000
