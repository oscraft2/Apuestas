# ── Telegram ──────────────────────────────────────────
TELEGRAM_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui
# Publicación automática del canal/grupo
TELEGRAM_PUBLISH_TOP_MATCHES=3
TELEGRAM_PUBLISH_MATCH_DETAILS=true
AUTO_WARMUP_ON_START=true
# Pasadas horarias desde el proceso API (necesario si solo sirves `main.py api` sin bot)
API_SCHEDULE_CENTRAL=true
# Guardar último análisis en data/cache/last_live_analysis.json (recomendado; usa volumen persistente en data/)
PERSIST_LIVE_SNAPSHOT=true
AUTO_PUBLISH_STARTUP_REPORT=false
STARTUP_ANALYSIS_DELAY_SEC=20
LINE_MOVE_POLL_INTERVAL_SEC=1800
RESULT_SYNC_INTERVAL_SEC=3600

# ── The Odds API ──────────────────────────────────────
# https://the-odds-api.com — 500 req/mes gratis
ODDS_API_KEY=tu_key_aqui

# ── API-Football ──────────────────────────────────────
# https://api-football.com — 100 req/día gratis
FOOTBALL_API_KEY=tu_key_aqui

# ── DeepSeek IA ───────────────────────────────────────
# https://platform.deepseek.com — 5M tokens gratis
DEEPSEEK_API_KEY=tu_key_aqui

# ── API REST (opcional) ───────────────────────────────
# Para el dashboard web. Ejecutar con: python main.py both
API_HOST=0.0.0.0
API_PORT=8000

# Panel Admin (acceso de operadores desde el pie del dashboard)
# ADMIN_TOKEN actúa como clave de entrada. ADMIN_SESSION_SECRET firma la cookie segura.
ADMIN_TOKEN=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_HOURS=12
ADMIN_COOKIE_SECURE=false
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Ligas y horarios del análisis central ─────────────
# IDs API-Football, separados por comas. Vacío = núcleo LATAM + ligas over/BTTS.
# https://www.api-football.com/documentation-v3#tag/Leagues
TARGET_LEAGUES=265,71,262,253,128,239,88,94,203,307

# Liga “protagonista”: pequeño boost en el ranking de destacados (default Chile 265).
HERO_LEAGUE_ID=265

# Horas UTC del análisis automático (3 pasadas por defecto).
REPORT_HOURS_UTC=8,15,22

# Capa editorial oficial
LEADER_TOP_N=5
LEADER_MIX_LEGS=3

# Regiones de casas para The Odds API (us ayuda a MLS/Liga MX; cuesta más crédito).
ODDS_REGIONS=us,eu,uk

# ── Frontend ──────────────────────────────────────────
# En frontend/.env.local:
# REACT_APP_API_URL=http://localhost:8000
